# =============================================================================
# SQLFlow Environment Variables
# =============================================================================
# Copy this file to .env and fill in values.
# Environment variables take precedence over config.yaml.
# Required variables are marked with [REQUIRED].
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# Server port (default: 8080)
SQLFLOW_SERVER_PORT=8080

# -----------------------------------------------------------------------------
# TLS Configuration
# -----------------------------------------------------------------------------
SQLFLOW_SERVER_TLS_ENABLE=false
SQLFLOW_SERVER_TLS_CERT_FILE=
SQLFLOW_SERVER_TLS_KEY_FILE=
SQLFLOW_SERVER_TLS_REDIRECT_HTTP=false
SQLFLOW_SERVER_TLS_HTTP_PORT=80

# -----------------------------------------------------------------------------
# Authentication [REQUIRED]
# -----------------------------------------------------------------------------
# JWT signing secret — must be at least 16 characters [REQUIRED]
SQLFLOW_JWT_SECRET=

# JWT token expiry duration (Go duration format, default: 15m)
SQLFLOW_JWT_EXPIRY=15m

# JWT refresh token expiry (default: 168h = 7 days)
SQLFLOW_JWT_REFRESH_EXPIRY=168h

# Admin credentials [REQUIRED]
SQLFLOW_ADMIN_USERNAME=admin
SQLFLOW_ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# SQLite database path (default: ./data/sqlflow.db)
SQLFLOW_DB_PATH=./data/sqlflow.db

# -----------------------------------------------------------------------------
# Encryption [REQUIRED]
# -----------------------------------------------------------------------------
# AES encryption key for sensitive data (16/24/32 hex chars) [REQUIRED]
# Generate with: openssl rand -hex 16
SQLFLOW_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# AI Review
# -----------------------------------------------------------------------------
# AI provider: openai, zhipu, azure (default: openai)
SQLFLOW_AI_PROVIDER=openai

# AI model name (default: gpt-4)
SQLFLOW_AI_MODEL=gpt-4

# AI API key — leave empty to disable AI review
SQLFLOW_AI_API_KEY=

# AI API base URL (default: https://api.openai.com/v1)
SQLFLOW_AI_BASE_URL=https://api.openai.com/v1

# AI request timeout (Go duration, default: 10s)
SQLFLOW_AI_TIMEOUT=10s

# -----------------------------------------------------------------------------
# Notifications
# -----------------------------------------------------------------------------
# DingTalk webhook URL
SQLFLOW_DINGTALK_WEBHOOK_URL=
SQLFLOW_DINGTALK_SECRET=

# Feishu webhook URL
SQLFLOW_FEISHU_WEBHOOK_URL=

# Generic webhook notification URL
SQLFLOW_NOTIFY_WEBHOOK_URL=

# Webhook signing secret
SQLFLOW_NOTIFY_SECRET=

# -----------------------------------------------------------------------------
# Backup
# -----------------------------------------------------------------------------
# Enable automatic database backups (default: false)
SQLFLOW_BACKUP_ENABLED=false

# Backup directory (default: ./data/backups)
SQLFLOW_BACKUP_DIR=./data/backups

# Backup interval (Go duration, default: 6h)
SQLFLOW_BACKUP_INTERVAL=6h

# Number of backups to keep (default: 10)
SQLFLOW_BACKUP_KEEP=10

# Compress backups with gzip (default: false)
SQLFLOW_BACKUP_COMPRESS=false

# -----------------------------------------------------------------------------
# Metrics
# -----------------------------------------------------------------------------
# Enable Prometheus metrics endpoint (default: false)
SQLFLOW_METRICS_ENABLED=false

# Prometheus metrics port (default: 9090)
SQLFLOW_METRICS_PORT=9090

# -----------------------------------------------------------------------------
# Query Settings
# -----------------------------------------------------------------------------
# Maximum query history entries per user (default: 200)
SQLFLOW_QUERY_HISTORY_MAX=200

# -----------------------------------------------------------------------------
# MySQL Database (for Docker Compose)
# -----------------------------------------------------------------------------
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=change-me-mysql-root-password
MYSQL_DATABASE=sqlflow

# -----------------------------------------------------------------------------
# Development only
# -----------------------------------------------------------------------------
SQLFLOW_DEBUG_PORT=2345
SQLFLOW_VITE_PORT=5173
SQLFLOW_VERSION=latest
BUILD_TIME=
