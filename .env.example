# ===== SQLFlow 环境变量配置 =====

# 服务器
SQLFLOW_SERVER_PORT=8080

# JWT
SQLFLOW_JWT_SECRET=change-me-to-a-random-string
SQLFLOW_JWT_EXPIRY=24h

# 管理员
SQLFLOW_ADMIN_USERNAME=admin
SQLFLOW_ADMIN_PASSWORD=change-me

# 加密
SQLFLOW_ENCRYPTION_KEY=change-me-32-byte-base64-key

# 数据库
SQLFLOW_DB_PATH=./data/sqlflow.db

# TLS（可选）
SQLFLOW_SERVER_TLS_ENABLE=false

# 指标（可选）
SQLFLOW_METRICS_ENABLED=false
SQLFLOW_METRICS_PORT=9090

# AI 审核（可选）
SQLFLOW_AI_PROVIDER=openai
SQLFLOW_AI_MODEL=gpt-4
SQLFLOW_AI_API_KEY=
SQLFLOW_AI_BASE_URL=https://api.openai.com/v1

# 钉钉通知（可选）
SQLFLOW_DINGTALK_WEBHOOK_URL=
SQLFLOW_DINGTALK_SECRET=
