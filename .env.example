# ===== SQLFlow 环境变量配置 =====

# 版本
SQLFLOW_VERSION=latest
BUILD_TIME=

# ----- Application -----
# Server
SQLFLOW_SERVER_PORT=8080

# JWT
SQLFLOW_JWT_SECRET=change-me-to-a-random-string
SQLFLOW_JWT_EXPIRY=24h

# Admin
SQLFLOW_ADMIN_USERNAME=admin
SQLFLOW_ADMIN_PASSWORD=change-me

# Encryption
SQLFLOW_ENCRYPTION_KEY=change-me-32-byte-base64-key

# Database (SQLite path inside container)
SQLFLOW_DB_PATH=/app/data/sqlflow.db

# TLS (optional — set true for production HTTPS)
SQLFLOW_SERVER_TLS_ENABLE=false
SQLFLOW_SERVER_TLS_CERT_FILE=
SQLFLOW_SERVER_TLS_KEY_FILE=
SQLFLOW_SERVER_TLS_REDIRECT_HTTP=false
SQLFLOW_SERVER_TLS_HTTP_PORT=80

# Metrics (optional)
SQLFLOW_METRICS_ENABLED=false
SQLFLOW_METRICS_PORT=9090

# AI review (optional)
SQLFLOW_AI_PROVIDER=openai
SQLFLOW_AI_MODEL=gpt-4
SQLFLOW_AI_API_KEY=
SQLFLOW_AI_BASE_URL=https://api.openai.com/v1

# DingTalk notification (optional)
SQLFLOW_DINGTALK_WEBHOOK_URL=
SQLFLOW_DINGTALK_SECRET=

# ----- MySQL Database -----
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=change-me-mysql-root-password
MYSQL_DATABASE=sqlflow

# ----- Development only -----
SQLFLOW_DEBUG_PORT=2345
SQLFLOW_VITE_PORT=5173
