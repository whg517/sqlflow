{
  "name": "sqlflow-e2e",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "test": "npx playwright test",
    "test:e2e": "npx playwright test",
    "test:smoke": "npx playwright test tests/smoke.spec.ts",
    "test:ci": "npx playwright test",
    "setup": "docker compose --env-file ../.env.test -f ../docker-compose.test.yml up -d --build --wait",
    "teardown": "docker compose --env-file ../.env.test -f ../docker-compose.test.yml down -v",
    "teardown:reset-db": "docker compose --env-file ../.env.test -f ../docker-compose.test.yml restart mysql-test",
    "report": "npx playwright show-report test-results/playwright-report",
    "lint": "npx tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.9.1",
    "typescript": "~5.7.0"
  }
}
