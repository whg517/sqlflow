{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "lib": ["ES2022", "DOM"],
    "types": ["node"]
  },
  "include": [
    "tests/**/*.ts",
    "fixtures/**/*.ts",
    "support/**/*.ts",
    "globalSetup.ts",
    "globalTeardown.ts"
  ]
}
