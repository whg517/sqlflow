# SQLFlow E2E Test Environment — Example Configuration
# ===================================================
# Copy this file to .env.test and fill in values.
# DO NOT commit .env.test to version control.
#
# Usage:
#   cp .env.test.example .env.test
#   docker compose --env-file .env.test -f docker-compose.test.yml up -d --build --wait

# --- SQLFlow Backend ---
SQLFLOW_SERVER_PORT=8080
SQLFLOW_JWT_SECRET=<generate: openssl rand -hex 32>
SQLFLOW_JWT_EXPIRY=24h
SQLFLOW_ADMIN_USERNAME=e2e-admin
SQLFLOW_ADMIN_PASSWORD=e2e-test-pass-123
SQLFLOW_ENCRYPTION_KEY=<generate: openssl rand -hex 16>
SQLFLOW_DB_PATH=/app/data/sqlflow-e2e.db
SQLFLOW_AI_PROVIDER=openai
SQLFLOW_AI_MODEL=gpt-4
SQLFLOW_AI_API_KEY=
SQLFLOW_AI_BASE_URL=https://api.openai.com/v1

# --- DingTalk (disabled for E2E) ---
SQLFLOW_DINGTALK_WEBHOOK_URL=
SQLFLOW_DINGTALK_SECRET=

# --- MySQL Test Database ---
MYSQL_ROOT_PASSWORD=e2e-mysql-root-123
MYSQL_DATABASE=testdb

# --- E2E Runner ---
E2E_BASE_URL=http://localhost:8080
E2E_USERNAME=e2e-admin
E2E_PASSWORD=e2e-test-pass-123
